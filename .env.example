POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_dev_password
POSTGRES_DB=investment_management
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=investment_management;Username=ims_user;Password=ims_dev_password
ASPNETCORE_ENVIRONMENT=Development
FeatureManagement__UseMockPayment=true
VITE_API_BASE_URL=http://localhost:5000
VITE_HUB_URL=http://localhost:5000/hubs/investment
VITE_IS_TESTING=true
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000
EXPO_PUBLIC_HUB_URL=http://localhost:5000/hubs/investment
EXPO_PUBLIC_IS_TESTING=true
Jwt__Issuer=InvestmentManagement
Jwt__Audience=InvestmentManagement
Jwt__SecretKey=InvestmentManagement_Dev_Secret_Key_32chars!
Jwt__ExpirationMinutes=60
